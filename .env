
# APP CONFIG

APP_NAME=MotoTrack 
ENV=development
DEBUG=True

# SECURITY / AUTH

SECRET_KEY=super_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# DATABASE (SQLite)

DATABASE_URL=sqlite:///./mototrack.db

# PASSWORD HASHING

BCRYPT_ROUNDS=12

# SCHEDULER

SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=UTC

# DEMO SETTINGS

DEMO_MODE=True
AUTO_SEED_DATA=True